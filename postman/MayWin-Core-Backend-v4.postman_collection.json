{
  "info": {
    "_postman_id": "maywin-core-backend-v4",
    "name": "MayWin Core Backend - v4",
    "description": "API Collection for MayWin Nurse Scheduling Platform Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Login (Step 1: Submit Credentials)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const jsonData = pm.response.json();",
                  "  if (jsonData.otpToken) {",
                  "    pm.environment.set('otpToken', jsonData.otpToken);",
                  "    pm.environment.set('requires2FA', jsonData.requires2FA);",
                  "    console.log('OTP sent to email. Check console for DEV OTP.');",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{loginEmail}}\", \"password\": \"{{loginPassword}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "2. Verify OTP (Step 2: Submit OTP Code)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const jsonData = pm.response.json();",
                  "  if (jsonData.accessToken) {",
                  "    pm.environment.set('authToken', jsonData.accessToken);",
                  "    pm.environment.set('userId', jsonData.user?.id);",
                  "    pm.environment.set('userEmail', jsonData.user?.email);",
                  "    pm.environment.set('userFullName', jsonData.user?.fullName);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"otpToken\": \"{{otpToken}}\", \"otp\": \"123456\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-otp"]
            }
          }
        },
        {
          "name": "3. Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const jsonData = pm.response.json();",
                  "  if (jsonData.accessToken) {",
                  "    pm.environment.set('authToken', jsonData.accessToken);",
                  "    pm.environment.set('userId', jsonData.user?.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"organizationId\": \"1\", \"unitId\": \"2\", \"email\": \"newuser@example.com\", \"password\": \"securepassword\", \"fullName\": \"Jane Smith\", \"roleCode\": \"NURSE\", \"attributes\": {}}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            }
          }
        },
        {
          "name": "4. Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "5. Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"deviceId\": \"postman-test\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Schedule",
      "item": [
        {
          "name": "Get Current Schedule",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/schedule?unitId={{unitId}}",
              "host": ["{{baseUrl}}"],
              "path": ["schedule"],
              "query": [
                {
                  "key": "unitId",
                  "value": "{{unitId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get Schedule Job Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/schedule-jobs/{{jobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["schedule-jobs", "{{jobId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Workers & Export",
      "item": [
        {
          "name": "Export Nurses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/nurses/export?unitId={{unitId}}",
              "host": ["{{baseUrl}}"],
              "path": ["nurses", "export"],
              "query": [
                {
                  "key": "unitId",
                  "value": "{{unitId}}"
                }
              ]
            }
          }
        },
        {
          "name": "List Workers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/units/{{unitId}}/workers",
              "host": ["{{baseUrl}}"],
              "path": ["units", "{{unitId}}", "workers"]
            }
          }
        }
      ]
    },
    {
      "name": "Orchestrator (Solver)",
      "item": [
        {
          "name": "Run Orchestrator",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const jsonData = pm.response.json();",
                  "  if (jsonData.jobId) {",
                  "    pm.environment.set('jobId', jsonData.jobId);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"scheduleId\": \"2\", \"idempotencyKey\": \"schedule-{{$timestamp}}-abc123\", \"dto\": {\"startDate\": \"2025-03-01T00:00:00.000Z\", \"endDate\": \"2025-03-31T23:59:59.999Z\", \"strategy\": {\"plan\": \"A\", \"mode\": \"strict\"}, \"solverConfig\": {\"timeLimitSeconds\": 120}, \"options\": {\"dryRun\": false}, \"notes\": \"30 nurses - 30 day schedule\", \"length\": 31}}"
            },
            "url": {
              "raw": "{{baseUrl}}/orchestrator/run",
              "host": ["{{baseUrl}}"],
              "path": ["orchestrator", "run"]
            }
          }
        }
      ]
    },
    {
      "name": "Staff Management",
      "item": [
        {
          "name": "List All Staff",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/staff",
              "host": ["{{baseUrl}}"],
              "path": ["staff"]
            }
          }
        },
        {
          "name": "Get Staff by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/staff/1",
              "host": ["{{baseUrl}}"],
              "path": ["staff", "1"]
            }
          }
        },
        {
          "name": "Create Staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const jsonData = pm.response.json();",
                  "  if (jsonData.staff?.id) {",
                  "    pm.environment.set('staffId', jsonData.staff.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"John Doe\", \"employeeId\": \"EMP001\", \"lineId\": \"line_johndoe\", \"position\": \"nurse\", \"email\": \"johndoe@maywin.local\", \"status\": \"active\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/staff",
              "host": ["{{baseUrl}}"],
              "path": ["staff"]
            }
          }
        },
        {
          "name": "Update Staff",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Jane Smith Updated\", \"email\": \"janesmith@maywin.local\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/staff/{{staffId}}",
              "host": ["{{baseUrl}}"],
              "path": ["staff", "{{staffId}}"]
            }
          }
        },
        {
          "name": "Delete Staff",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/staff/{{staffId}}",
              "host": ["{{baseUrl}}"],
              "path": ["staff", "{{staffId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Audit Logs",
      "item": [
        {
          "name": "List Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/audit-logs",
              "host": ["{{baseUrl}}"],
              "path": ["audit-logs"]
            }
          }
        },
        {
          "name": "Export Audit Logs (CSV)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/audit-logs?export=csv",
              "host": ["{{baseUrl}}"],
              "path": ["audit-logs"],
              "query": [
                {
                  "key": "export",
                  "value": "csv"
                }
              ]
            }
          }
        },
        {
          "name": "Create Audit Log",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"action\": \"APPROVE_REQUEST\", \"targetType\": \"request\", \"targetId\": \"REQ001\", \"detail\": \"Approved shift swap\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/audit-logs",
              "host": ["{{baseUrl}}"],
              "path": ["audit-logs"]
            }
          }
        }
      ]
    }
  ],
