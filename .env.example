# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3005
# Set to 127.0.0.1 when a reverse proxy (nginx/ALB) handles public traffic (INF-001)
BIND_HOST=127.0.0.1
ALLOWED_ORIGINS=https://app.example.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=your-rds-endpoint.ap-southeast-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=maywin_prod
DB_PASSWORD=
DB_NAME=maywin
DB_SCHEMA=public

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
REDIS_URL=redis://your-elasticache-endpoint:6379

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_SECRET_NAME=maywin/production
# Step Functions state machine ARN (INF-009 — MAYWIN_SFN_ARN is deprecated)
SCHEDULE_WORKFLOW_ARN=arn:aws:states:ap-southeast-1:123456789012:stateMachine:MayWinScheduler
MAYWIN_ARTIFACTS_BUCKET=maywin-artifacts-prod

# ── LINE Messaging API ────────────────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ── AI / Solver ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
SOLVER_PYTHON=python3
SOLVER_CLI_PATH=src/core/solver/solver_cli.py
ORCHESTRATION_MODE=STEP_FUNCTIONS

# ── Mail ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
